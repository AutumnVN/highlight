{
    "name": "highlight",
    "description": "Highlight any raw code text and beautify HTML, CSS, JS",
    "version": "0.0.1",
    "manifest_version": 2,
    "author": "AutumnVN",
    "background": {
        "scripts": [
            "background.js"
        ]
    },
    "permissions": [
        "webRequest",
        "webRequestBlocking",
        "https://raw.githubusercontent.com/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "shiki/shiki.js",
                "beautify/html.js",
                "beautify/css.js",
                "beautify/js.js",
                "content.js"
            ],
            "css": [
                "shiki/style.css"
            ]
        }
    ],
    "web_accessible_resources": [
        "shiki/*"
    ]
}
